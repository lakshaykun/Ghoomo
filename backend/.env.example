# ============================================================
# Ghoomo Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit real secrets.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Database (Supabase / Postgres) ───────────────────────────
# Provide ONE of the two aliases — both are accepted.
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Disable SSL for local Postgres (set to true for Supabase cloud)
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=false

# Optional pool tuning
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000

# ── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ── Firebase Admin (server-side token verification) ───────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for open (dev only)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────
SUPABASE_BOOTSTRAP_FROM_JSON=false

# ── External services ─────────────────────────────────────────
PLACE_SEARCH_TIMEOUT_MS=6000
