# Environment Configuration Template
# Copy this to .env file and fill in your values

# App Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghoomo
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=*

# External Services
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
GOOGLE_MAPS_API_KEY=
