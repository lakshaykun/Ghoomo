# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your Apps > Web
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id_here
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Google OAuth Configuration
# Configure per platform from Google Cloud Console > APIs & Services > Credentials
# Web client ID (also used by Firebase credential exchange)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# iOS OAuth client ID (bundle-specific)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
# Android OAuth client ID (package + SHA-specific)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
# Expo Go client ID (optional but useful in development)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your_expo_client_id.apps.googleusercontent.com
# Backward-compatible fallback if WEB_CLIENT_ID is not set
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional: API Base URL (uncomment and modify if needed)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
