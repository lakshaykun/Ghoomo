{
  "name": "ghoomo-platform",
  "version": "1.0.0",
  "description": "Ghoomo - Professional Ride-Sharing Platform (Monorepo)",
  "private": true,
  "workspaces": [
    "app",
    "backend",
    "web"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix app && npm install --prefix backend",
    "start": "npm run start:app",
    "start:app": "npm start --prefix app",
    "start:backend": "npm start --prefix backend",
    "start:web": "npm run serve --prefix web",
    "start:all": "concurrently \"npm run start:app\" \"npm run start:backend\" \"npm run serve --prefix web\"",
    "build:app": "npm run build --prefix app",
    "build:android": "npm run build:android:apk --prefix app",
    "build:ios": "npm run build:ios --prefix app",
    "build:backend": "npm run build --prefix backend",
    "build:web": "npm run build --prefix web",
    "test": "npm test --prefix app && npm test --prefix backend",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "clean": "rm -rf app/node_modules backend/node_modules node_modules && rm -rf app/.expo backend/.build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "rideshare",
    "ride-hailing",
    "transportation",
    "platform"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ghoomo/platform.git"
  },
  "bugs": {
    "url": "https://github.com/ghoomo/platform/issues"
  },
  "homepage": "https://ghoomo.com"
}
