# ============================================================
# Ghoomo Admin Web (Vite) — Environment Configuration
# All variables must be prefixed VITE_ to be exposed to the browser.
# Copy to web/.env and fill in your values.
# NEVER commit real secrets.
# ============================================================

# ── Backend API ───────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api

# ── Supabase (direct client access, if needed) ───────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
