{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_NEW_ARCH_ENABLED": "1",
        "EXPO_PUBLIC_API_BASE_URL": "https://backend-fawn-seven-41.vercel.app"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_NEW_ARCH_ENABLED": "1",
        "EXPO_PUBLIC_API_BASE_URL": "https://backend-fawn-seven-41.vercel.app"
      }
    },
    "production-apk": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
